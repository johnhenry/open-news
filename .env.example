NODE_ENV=development
PORT=3000
API_PORT=3001
HOST=0.0.0.0

# Database
DB_PATH=./data/news.db

# Security
# Admin API key for protected settings routes (leave blank to disable auth in dev)
ADMIN_API_KEY=

# CORS - comma-separated list of allowed origins (leave blank for localhost in dev)
CORS_ORIGINS=

# Ingestion
INGEST_INTERVAL=*/15 * * * *
CLUSTER_INTERVAL=*/30 * * * *

# Mode (safe or research)
CONTENT_MODE=safe

# NLP
MAX_ARTICLE_LENGTH=10000

# Clustering
MIN_CLUSTER_SIZE=2
SIMILARITY_THRESHOLD=0.7

# LLM Configuration
LLM_ADAPTER=ollama

# OpenAI API Key (required for OpenAI adapter)
OPENAI_API_KEY=

# Anthropic API Key (required for Anthropic adapter)
ANTHROPIC_API_KEY=

# Google Gemini API Key (required for Gemini adapter)
GEMINI_API_KEY=

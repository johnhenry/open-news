{
  "name": "open-news",
  "version": "1.0.0",
  "description": "Open-source Ground News-style news aggregator for comparing coverage across political spectrum",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server-dev.js",
    "dev:old": "nodemon src/server.js",
    "dev:split": "concurrently \"npm run dev:old\" \"cd frontend && npm run dev\"",
    "build": "cd frontend && npm run build",
    "build:prod": "npm run build && node src/server-prod.js",
    "preview": "npm run build && node src/server-prod.js",
    "migrate": "node src/db/migrate.js",
    "ingest": "node src/jobs/ingest.js",
    "cluster": "node src/jobs/cluster.js",
    "llm": "node src/llm/cli.js",
    "seed": "node src/utils/seed-sources.js",
    "test": "jest",
    "docker:build": "docker build -t open-news .",
    "docker:run": "docker run -p 3000:3000 -p 3001:3001 open-news"
  },
  "keywords": [
    "news",
    "aggregator",
    "bias",
    "media",
    "journalism"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^11.5.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "fastify": "^5.7.2",
    "ml-distance": "^4.0.1",
    "ml-kmeans": "^6.0.0",
    "natural": "^6.10.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "rss-parser": "^3.13.0",
    "@fastify/static": "^9.0.0"
  },
  "devDependencies": {
    "@fastify/middie": "^8.3.3",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "vite": "^7.1.5"
  }
}
